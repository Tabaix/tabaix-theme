{
  "name": "tabaix-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run watch:css & npm run watch:js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "postcss assets/css/main.css -o assets/css/main.min.css --watch",
    "watch:js": "esbuild assets/js/main.js --bundle --outfile=assets/js/main.min.js --watch",
    "build:css": "postcss assets/css/main.css -o assets/css/main.min.css --env production",
    "build:js": "esbuild assets/js/main.js --bundle --minify --outfile=assets/js/main.min.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "cssnano": "^6.0.1",
    "esbuild": "^0.18.11",
    "postcss": "^8.4.24",
    "postcss-cli": "^10.1.0"
  }
}
